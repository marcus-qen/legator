# Secret patterns — one regex per line
# Used by pre-commit hook to block commits containing secrets

# HashiCorp Vault tokens
hvs\.[A-Za-z0-9]{10,}

# OpenAI API keys
sk-proj-[A-Za-z0-9_-]{20,}

# Anthropic API keys
sk-ant-[A-Za-z0-9_-]{10,}

# Legator API keys (full hex, not short test values)
lgk_[a-f0-9]{20,}

# AWS access key IDs
AKIA[0-9A-Z]{16}

# Private keys
-----BEGIN.*PRIVATE KEY-----

# Bearer tokens in code (not test fixtures)
Bearer\s+[A-Za-z0-9._~+/=-]{20,}

# Password assignments with long values
password.*=.*[A-Za-z0-9+/]{32,}

# Generic credential assignments
(api_key|secret_key|access_token|auth_token)\s*[=:]\s*["']?[A-Za-z0-9+/._-]{20,}
