#!/usr/bin/env bash
# Combined pre-commit hook: secrets + large files + merge conflicts + repo-specific checks
# Install: cd .git/hooks && ln -sf ../../hooks/pre-commit pre-commit
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
FAILED=0

# ── Secret scanning ──────────────────────────────────────────────────
PATTERNS_FILE="$REPO_ROOT/.secret-patterns"
if [ -f "$PATTERNS_FILE" ]; then
    STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
    if [ -n "$STAGED" ]; then
        echo "🔒 Scanning for secrets..."
        while IFS= read -r pattern; do
            [[ -z "$pattern" || "$pattern" =~ ^# ]] && continue
            for file in $STAGED; do
                [[ "$file" == ".secret-patterns" || "$file" == hooks/* || "$file" == *.db ]] && continue
                if [ -f "$REPO_ROOT/$file" ]; then
                    MATCHES=$(grep -nP "$pattern" "$REPO_ROOT/$file" 2>/dev/null || true)
                    if [ -n "$MATCHES" ]; then
                        echo "🚨 SECRET in $file:"
                        echo "$MATCHES" | head -3
                        echo "   Pattern: $pattern"
                        FAILED=1
                    fi
                fi
            done
        done < "$PATTERNS_FILE"
    fi
fi

# ── Large file check (>1MB) ──────────────────────────────────────────
echo "📏 Checking file sizes..."
while IFS= read -r file; do
    [ -z "$file" ] && continue
    if [ -f "$REPO_ROOT/$file" ]; then
        SIZE=$(wc -c < "$REPO_ROOT/$file")
        if [ "$SIZE" -gt 1048576 ]; then
            SIZE_MB=$(awk "BEGIN{printf \"%.1f\", $SIZE/1048576}")
            echo "🚨 LARGE FILE: $file (${SIZE_MB}MB > 1MB limit)"
            echo "   Use .gitignore or git-lfs for large files."
            FAILED=1
        fi
    fi
done < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

# ── Merge conflict markers ───────────────────────────────────────────
echo "🔀 Checking for merge conflicts..."
while IFS= read -r file; do
    [ -z "$file" ] && continue
    [[ "$file" == *.db || "$file" == *.png || "$file" == *.jpg ]] && continue
    if [ -f "$REPO_ROOT/$file" ]; then
        if grep -qnE '^(<{7}|={7}|>{7})' "$REPO_ROOT/$file" 2>/dev/null; then
            echo "🚨 MERGE CONFLICT MARKERS in $file"
            grep -nE '^(<{7}|={7}|>{7})' "$REPO_ROOT/$file" | head -3
            FAILED=1
        fi
    fi
done < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

# ── gofmt check (Go repos only) ──────────────────────────────────────
if command -v gofmt &>/dev/null; then
    GO_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep '\.go$' || true)
    if [ -n "$GO_FILES" ]; then
        echo "🔧 Checking gofmt..."
        UNFORMATTED=""
        for file in $GO_FILES; do
            if [ -f "$REPO_ROOT/$file" ]; then
                if [ -n "$(gofmt -l "$REPO_ROOT/$file" 2>/dev/null)" ]; then
                    UNFORMATTED="$UNFORMATTED $file"
                fi
            fi
        done
        if [ -n "$UNFORMATTED" ]; then
            echo "🚨 NOT FORMATTED (run gofmt -w):"
            for f in $UNFORMATTED; do echo "   $f"; done
            FAILED=1
        fi
    fi
fi

# ── SOPS validation (dev-lab only) ───────────────────────────────────
SOPS_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep '\.sops\.yaml$' || true)
if [ -n "$SOPS_FILES" ]; then
    echo "🔐 Validating SOPS encryption..."
    for file in $SOPS_FILES; do
        if [ -f "$REPO_ROOT/$file" ]; then
            if ! grep -q 'ENC\[AES256_GCM,' "$REPO_ROOT/$file" 2>/dev/null; then
                echo "🚨 UNENCRYPTED SOPS FILE: $file"
                echo "   This file must be encrypted before commit."
                echo "   Run: sops -e -i $file"
                FAILED=1
            fi
        fi
    done
fi

# ── Result ────────────────────────────────────────────────────────────
if [ "$FAILED" -eq 1 ]; then
    echo ""
    echo "================================================================"
    echo "❌ COMMIT BLOCKED — fix the issues above."
    echo "   Bypass (EMERGENCY ONLY): git commit --no-verify"
    echo "================================================================"
    exit 1
fi

echo "✅ All checks passed."
